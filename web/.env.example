# --- Supabase ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never exposed to the browser

# --- X / Twitter (server-side, the operator's key) ---
X_BEARER_TOKEN=your-x-api-bearer-token

# --- Anthropic (synthesis) ---
ANTHROPIC_API_KEY=your-anthropic-key
# Optional model overrides:
# REPOST_EXPANSION_MODEL=claude-haiku-4-5
# REPOST_SYNTHESIS_MODEL=claude-opus-4-8

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://repost.blog
