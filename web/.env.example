# repost.blog is READ-ONLY. It never fetches X and never calls an LLM, so there
# is NO X_BEARER_TOKEN and NO ANTHROPIC_API_KEY here. Generation happens on
# clients (the repost MCP/engine, BYO-key) which publish to /api/contribute.

# --- Supabase ---
# Settings → API in your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key          # public read (RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key       # server-only; used by /api/contribute writes

# --- Contributor allowlist (who may publish) ---
# Comma-separated "label:token" pairs. The label is recorded as the brief's
# contributor; the token is what the client sends as a Bearer token.
# e.g. REPOST_PUBLISH_TOKENS=paulg:s3cr3t-aaa,karpathy:s3cr3t-bbb
REPOST_PUBLISH_TOKENS=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://repost.blog
